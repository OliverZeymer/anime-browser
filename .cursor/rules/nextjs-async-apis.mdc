# Next.js Async APIs

In Next.js 15+, `params`, `searchParams`, `cookies()`, and `headers()` are asynchronous.

## Async Params and SearchParams

Always type them as `Promise<...>` and `await` them:

```tsx
type Props = {
  params: Promise<{ slug: string }>;
};

export const InstructorPage = async ({ params }: Props) => {
  const { slug } = await params;
  // use slug
};

export default InstructorPage;
```

SearchParams:

```tsx
type Props = {
  params: Promise<{ slug: string }>;
  searchParams: Promise<{ query?: string }>;
};

export const SearchPage = async ({ params, searchParams }: Props) => {
  const { slug } = await params;
  const { query } = await searchParams;
  // use slug and query
};

export default SearchPage;
```

## Synchronous Components

Use `React.use()` in non-async components that need params:

```tsx
import { use } from 'react';

type Props = {
  params: Promise<{ slug: string }>;
};

export const InstructorPage = ({ params }: Props) => {
  const { slug } = use(params);
  // use slug
};

export default InstructorPage;
```

## Async Cookies and Headers

```tsx
import { cookies, headers } from 'next/headers';

export const SomePage = async () => {
  const cookieStore = await cookies();
  const headersList = await headers();

  const theme = cookieStore.get('theme');
  const userAgent = headersList.get('user-agent');
};

export default SomePage;
```

## Route Handlers

```ts
export const GET = async (
  request: Request,
  { params }: { params: Promise<{ id: string }> }
) => {
  const { id } = await params;
  // handle request
};
```

## generateMetadata

```tsx
type Props = {
  params: Promise<{ slug: string }>;
};

export const generateMetadata = async ({ params }: Props): Promise<Metadata> => {
  const { slug } = await params;
  return { title: slug };
};
```
